{
  "@context": "https://ksnlabs.dev/ontology/",
  "@type": "SessionLearnings",
  "date": "2026-03-10",
  "sessionId": "lumo-mcp-build + lumo-verification",
  "model": "Claude Opus 4.6",
  "learnings": [
    {
      "id": "L076",
      "category": "infrastructure",
      "title": "All MCP servers can die simultaneously",
      "lesson": "All four MCP servers (DC, UDC, filesystem, GitHub) dropped at the same time during a claude.ai web session. Only Gmail survived. Failure is silent. Makes DC unsuitable as sole filesystem bridge.",
      "severity": "CRITICAL"
    },
    {
      "id": "L077",
      "category": "architecture",
      "title": "MCP stdio transport for local tools",
      "lesson": "StdioServerTransport is correct for local tools. Claude Desktop spawns process, communicates via stdin/stdout JSON-RPC. No HTTP port, no firewall, no orphans.",
      "severity": "HIGH"
    },
    {
      "id": "L078",
      "category": "tooling",
      "title": "ESM-CJS bridge via createRequire",
      "lesson": "MCP SDK needs ESM. Electron uses CJS. Bridge: import { createRequire } from 'module'; const require = createRequire(import.meta.url); .mjs forces ESM, core.js stays CJS.",
      "severity": "MEDIUM"
    },
    {
      "id": "L079",
      "category": "tooling",
      "title": "Lumo git tools fail with cmd.exe ENOENT on BIGSPIDER",
      "lesson": "core.js uses execSync for git commands. The MCP server process spawned by Claude Desktop may not have cmd.exe on PATH. lumo_git_status and lumo_git_exec both fail with 'spawnSync cmd.exe ENOENT'. Fix: add { shell: true } to execSync options, or specify shell path explicitly. lumo_execute_command may have the same issue. Workaround: use lumo_read_file/write_file for file ops, and bash_tool or manual git for now.",
      "severity": "HIGH"
    }
  ]
}

